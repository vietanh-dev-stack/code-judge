{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Debug Core API (NestJS)",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev:debug",
        "-w",
        "@code-judge/core-api"
      ],
      "port": 9229,
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    },
    {
      "name": "Debug Worker",
      "type": "node",
      "request": "launch",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev:debug",
        "-w",
        "@code-judge/worker"
      ],
      "port": 9230,
      "console": "integratedTerminal",
      "restart": true,
      "skipFiles": [
        "<node_internals>/**"
      ]
    }
  ]
}
