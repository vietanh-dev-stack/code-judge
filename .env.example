# Gợi ý cho dev local (Docker: `docker compose up -d` tại root repo).
# Mỗi app nên có file `.env` riêng: copy từ `apps/<tên-app>/.env.example`.

# --- Dùng chung (Core API + Worker) ---
DATABASE_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge
REDIS_URL=redis://localhost:6379

# --- Chủ yếu Core API ---
JWT_SECRET=change-me-in-production
# JWT_EXPIRES_IN=900
# JWT_REFRESH_SECRET=change-me-refresh-secret
# JWT_REFRESH_EXPIRES_IN=604800
# FRONTEND_URL=http://localhost:3001

# --- Google OAuth (tuỳ chọn) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback

# --- MinIO (Core API + Worker) ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codejudge
MINIO_REGION=us-east-1
# MINIO_PUBLIC_BASE_URL=http://localhost:9000

# --- Web (Next.js, prefix NEXT_PUBLIC_) ---
NEXT_PUBLIC_CORE_URL=http://localhost:3000
