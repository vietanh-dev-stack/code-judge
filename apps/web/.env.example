# --- Browser: REST + Socket.io tới Core API ---
# Phải trùng host/port nơi chạy `apps/core-api` (mặc định dev: 3000).
# Web Next.js chạy port khác (script dev thường dùng 3001); không nhầm với biến này.
NEXT_PUBLIC_CORE_URL=http://localhost:3000

# --- Next.js (tuỳ chọn) ---
# `npm run dev` đang cố định `-p 3001`; chỉ cần PORT nếu bạn bỏ -p hoặc deploy.
# PORT=3001

# --- Tuỳ chọn / tương lai ---
# NEXT_PUBLIC_APP_NAME=Code Judge
# ANALYZE=false
