# --- HTTP ---
# Cổng Core API (mặc định 3000 nếu không set).
PORT=3000

# --- Dữ liệu & hàng đợi (khớp `docker-compose.yml` ở root repo) ---
DATABASE_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge
REDIS_URL=redis://localhost:6379

# Dữ liệu mẫu dev/test: npm run prisma:seed — xem docs/PRISMA-SEED.md

# --- JWT (bắt buộc khi chạy AuthModule) ---
JWT_SECRET=change-me-in-production
# Access token expiry (giây). Mặc định trong code: 900 (15 phút).
# JWT_EXPIRES_IN=900
# Refresh token secret (nếu không set sẽ dùng JWT_SECRET + '-refresh')
# JWT_REFRESH_SECRET=change-me-refresh-secret
# Refresh token expiry (giây). Mặc định trong code: 604800 (7 ngày).
# JWT_REFRESH_EXPIRES_IN=604800

# --- Google OAuth (tuỳ chọn, chỉ cần khi dùng /auth/google) ---
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=http://localhost:3000/auth/google/callback
# FRONTEND_URL=http://localhost:3001

# --- Swagger OpenAPI ---
# Tắt UI: SWAGGER_ENABLED=0. Tự tắt khi NODE_ENV=production.
# SWAGGER_ENABLED=1
# NODE_ENV=development

# --- Tuỳ chọn / tương lai ---
# APP_ENV=dev
# DIRECT_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# AI_DEFAULT_PROVIDER=openai
# AI_DEFAULT_MODEL_OPENAI=gpt-4.1-mini
# AI_DEFAULT_MODEL_GOOGLE=gemini-2.5-flash
# AI_PROMPT_VERSION=ai-testcase-v1
# AI_FAST_MODE=true
# AI_MAX_TOKENS=4096
# (Code also applies a floor from maxTestCases so JSON is not cut mid-array.)
# AI_MAX_TOKENS=10000
# AI_TEMPERATURE=0.2
# AI_HINT_ENABLED=true
# AI_HINT_MAX_PER_PROBLEM_PER_HOUR=10
# AI_HINT_DISABLED_IN_CONTEST=true
# CLOUDINARY_URL=
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codejudge
MINIO_REGION=us-east-1
# Nếu cần render URL public trực tiếp (VD Nginx reverse proxy):
MINIO_PUBLIC_BASE_URL=http://localhost:9000
GOOGLE_GENERATIVE_AI_API_KEY=AIzaSyD4TWu7QMohRMa_SSzSSRmE1-wcONf6rsM
AI_DEFAULT_PROVIDER=google
AI_DEFAULT_MODEL_OPENAI=gpt-4.1-mini
AI_DEFAULT_MODEL_GOOGLE=gemini-2.5-flash
AI_PROMPT_VERSION=ai-testcase-v1
AI_FAST_MODE=auto
AI_MAX_TOKENS=10000
AI_TEMPERATURE=0.2