              "mode": "raw",
              "raw": "{\n  \"name\": \"CRUD User\",\n  \"email\": \"crud-user-{{$timestamp}}@example.com\",\n  \"password\": \"Secret12!\",\n  \"role\": \"STUDENT\"\n}"
