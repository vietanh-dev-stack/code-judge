    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "try {",
                  "  const res = pm.response.json();",
                  "  if (res.success && res.result && res.result.accessToken) {",
                  "    pm.collectionVariables.set('accessToken', res.result.accessToken);",
                  "  }",
                  "} catch (e) {}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [{ "key": "Content-Type", "value": "application/json" }],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"{{testUserName}}\",\n  \"email\": \"{{testEmail}}\",\n  \"password\": \"{{testPassword}}\"\n}"
            },
            "url": "{{baseUrl}}/auth/register",
            "description": "Tạo user mới. Lưu `accessToken` vào biến collection nếu thành công."
          },
          "response": []
        },
        {
          "name": "Login",
