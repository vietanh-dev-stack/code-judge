DATABASE_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge

# --- Redis (BullMQ consumer) ---
# Mặc định trong code: redis://localhost:6379 nếu không set.
REDIS_URL=redis://localhost:6379

# --- MinIO / Object storage ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codejudge
MINIO_REGION=us-east-1

# --- Tuỳ chọn ---
# NODE_ENV=development

# Chấm submission: judge0 (mặc định) hoặc lambda (invoke AWS, để test)
# JUDGE_ENGINE=judge0
# JUDGE_ENGINE=lambda
# JUDGE_LAMBDA_FUNCTION_NAME=my-judge-fn

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Lambda cho golden-verify (và mặc định cho judge nếu không set JUDGE_LAMBDA_FUNCTION_NAME)
AWS_LAMBDA_FUNCTION_NAME=
JUDGE0_URL=http://localhost:2358