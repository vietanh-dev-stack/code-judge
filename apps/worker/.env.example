DATABASE_URL=postgresql://codejudge:codejudge@localhost:5432/codejudge

# --- Redis (BullMQ consumer) ---
# Mặc định trong code: redis://localhost:6379 nếu không set.
REDIS_URL=redis://localhost:6379

# --- MinIO / Object storage ---
MINIO_ENDPOINT=localhost
MINIO_PORT=9000
MINIO_USE_SSL=false
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_BUCKET=codejudge
MINIO_REGION=us-east-1

# --- Tuỳ chọn ---
# NODE_ENV=development

# Chấm submission: judge0 (mặc định) hoặc lambda (invoke AWS, để test)
# JUDGE_ENGINE=judge0
# JUDGE_ENGINE=lambda
# JUDGE_LAMBDA_FUNCTION_NAME=my-judge-fn

AWS_REGION=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
# Lambda cho golden-verify Java/C++/… (và judge nếu JUDGE_ENGINE=lambda)
AWS_LAMBDA_FUNCTION_NAME=
# Python golden-verify: true = chạy python/py trên máy worker (khuyến nghị dev). false = luôn Lambda nếu có AWS_LAMBDA_FUNCTION_NAME.
GOLDEN_VERIFY_PREFER_LOCAL_PYTHON=true
JUDGE0_URL=http://localhost:2358

# --- Time / memory limits (submission judge + calibrate-limits) ---
# LIMIT_TIME_SAFETY=2
# LIMIT_MEM_SAFETY=1.5
# LIMIT_LANGUAGE_MULTIPLIERS={"PYTHON":2,"JAVASCRIPT":2,"JAVA":2,"CPP":1}
# true khi VPS dùng isolate thật + cgroup v1 (xem docs/JUDGE0-CGROUP-V1-MIGRATION.md)
# JUDGE0_MEMORY_ENFORCED=false