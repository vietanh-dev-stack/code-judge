{
  "name": "code-judge",
  "private": true,
  "workspaces": [
    "apps/*"
  ],
  "scripts": {
    "dev": "npm run dev -ws --if-present",
    "dev:debug": "npm run dev:debug -w @code-judge/core-api",
    "dev:debug:worker": "npm run dev:debug -w @code-judge/worker",
    "build": "npm run build -ws --if-present",
    "start": "npm run start -ws --if-present",
    "test": "npm run test -w @code-judge/core-api --if-present && node --test ci/smoke.test.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@eslint/js": "^9.15.0",
    "@types/nodemailer": "^8.0.0",
    "@types/uuid": "^10.0.0",
    "eslint": "^9.15.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.4.2",
    "typescript-eslint": "^8.15.0"
  },
  "dependencies": {
    "jest": "^30.4.2",
    "nodemailer": "^8.0.7",
    "sonner": "^2.0.7"
  }
}
