# Ubuntu 24.04 LTS x64 VPS — copy to .env.production (never commit .env.production)
#
# Đưa code lên VPS qua SSH (KHÔNG git clone GitHub): xem deploy/README.md
#   Windows: .\deploy\sync-to-vps.ps1 -VpsHost VPS_IP
#   VPS lần đầu: ./deploy/ubuntu-24.04-setup.sh
#   cp .env.production.example .env.production
#   ./deploy/production-up.sh

# ─── Postgres (app-db) ───────────────────────────────────────────────────
POSTGRES_USER=codejudge
POSTGRES_PASSWORD=change-me-strong-postgres-password
POSTGRES_DB=codejudge

# ─── MinIO ─────────────────────────────────────────────────────────────────
MINIO_ROOT_USER=codejudge_minio
MINIO_ROOT_PASSWORD=change-me-strong-minio-password
MINIO_BUCKET=codejudge
MINIO_REGION=us-east-1
# URL host mà **trình duyệt** dùng khi PUT/GET presigned lên MinIO.
# Local: http://localhost:9000
# VPS HTTPS (nginx proxy /codejudge/ → minio): https://your-domain.com (không :9000 — tránh Mixed Content)
MINIO_PUBLIC_BASE_URL=http://localhost:9000
# MINIO_PUBLIC_BASE_URL=https://your-domain.com
# Bucket public read — production: false (chỉ presign). Dev local: true nếu cần URL tĩnh cũ.
MINIO_ALLOW_PUBLIC_READ=false
# Đổi cổng nếu 9000 bận: đồng thời sửa MINIO_PUBLIC_BASE_URL cho khớp
# MINIO_HOST_PORT=9002

# ─── Judge0 ────────────────────────────────────────────────────────────────
JUDGE0_DB_PASSWORD=change-me-judge0-db
# openssl rand -hex 64
JUDGE0_SECRET_KEY_BASE=change-me-judge0-rails-secret-at-least-64-chars-long-random-string
# false = isolate_stub (mặc định compose). true = isolate thật + file docker-compose.production-judge0-isolate.yml
JUDGE0_USE_CGROUP=false
# Khi JUDGE0_USE_CGROUP=true (sau GRUB cgroup v1 — docs/JUDGE0-CGROUP-V1-MIGRATION.md):
# JUDGE0_USE_CGROUP=true
# JUDGE0_MEMORY_ENFORCED=true
# LIMIT_TIME_SAFETY=2
# LIMIT_MEM_SAFETY=1.5

# ─── App secrets ───────────────────────────────────────────────────────────
JWT_SECRET=change-me-jwt-secret-min-32-chars
# JWT_REFRESH_SECRET=
JWT_EXPIRES_IN=900
JWT_REFRESH_EXPIRES_IN=604800

# URL web mà Core API dùng cho CORS + redirect OAuth (phải khớp origin trình duyệt — gồm cổng nếu có).
# Khớp origin trên thanh địa chỉ; thêm www nếu site truy cập được bằng www:
FRONTEND_URL=https://your-domain.com,https://www.your-domain.com

# URL API mà trình duyệt gọi (build-time cho Next.js — phải khớp khi build image web)
NEXT_PUBLIC_CORE_URL=https://api.your-domain.com

# Bắt buộc khi web + API khác subdomain (middleware Next đọc cookie trên web).
COOKIE_DOMAIN=.your-domain.com
# Khớp COOKIE_DOMAIN — build web dùng xóa cookie cũ đúng domain khi refresh thất bại.
# NEXT_PUBLIC_COOKIE_DOMAIN=.your-domain.com

# Docker Desktop / nginx mặc định (web :80, API :8080) — không dùng :3000 trừ khi bạn chạy Next dev riêng.
# FRONTEND_URL=http://localhost
# NEXT_PUBLIC_CORE_URL=http://localhost:8080

# Nhiều origin cùng lúc (vd. vừa nginx :80 vừa dev Next :3000):
# FRONTEND_URL=http://localhost,http://localhost:3000

# Chỉ IP trên Ubuntu VPS (nginx: web :80, API :8080):
# FRONTEND_URL=http://203.0.113.10
# NEXT_PUBLIC_CORE_URL=http://203.0.113.10:8080

# ─── Google OAuth (tuỳ chọn) ───────────────────────────────────────────────
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_CALLBACK_URL=https://api.your-domain.com/auth/google/callback

# ─── Email (Gmail qua nodemailer — tuỳ chọn) ────────────────────────────────
# Core API trong docker-compose.production nhận MAIL_* từ đây. Để trống = không gửi mời lớp / thông báo mail.
# Dùng App Password Google: https://myaccount.google.com/apppasswords
# MAIL_ACCOUNT=your@gmail.com
# MAIL_PASSWORD=xxxx-xxxx-xxxx-xxxx

# ─── AI testcase (tuỳ chọn) ────────────────────────────────────────────────
# OPENAI_API_KEY=
# GOOGLE_GENERATIVE_AI_API_KEY=
# AI_DEFAULT_PROVIDER=google
# AI_DEFAULT_MODEL_GOOGLE=gemini-2.5-flash

# ─── AWS Lambda judge (tuỳ chọn, thay Judge0) ─────────────────────────────
# JUDGE_ENGINE=judge0
# AWS_REGION=ap-southeast-1
# AWS_ACCESS_KEY_ID=
# AWS_SECRET_ACCESS_KEY=
# AWS_LAMBDA_FUNCTION_NAME=

# ─── Nginx ─────────────────────────────────────────────────────────────────
HTTP_PORT=80
# API qua nginx (khi chỉ có IP): http://VPS_IP:8080
API_HTTP_PORT=8080
# HTTPS (compose map host:container). Cần cert trên host tại /etc/letsencrypt — xem deploy/README.md mục HTTPS.
# HTTPS_PORT=443

# Sau `migrate`: mặc định chạy `prisma db seed`. DB production thật (không ghi đè seed): RUN_SEED=0
# RUN_SEED=0

# ─── Auth (rate limit + helmet) ─────────────────────────────────────────────
AUTH_LOGIN_MAX_ATTEMPTS=10
AUTH_LOGIN_WINDOW_SECONDS=900
AUTH_REGISTER_MAX_PER_IP=5
AUTH_REGISTER_WINDOW_SECONDS=3600
HELMET_ENABLED=true

# ─── Swagger (tắt trên production) ─────────────────────────────────────────
SWAGGER_ENABLED=0
